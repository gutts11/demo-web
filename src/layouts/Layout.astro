---
import '@fontsource/inter';
import '@fontsource/playfair-display';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Professional construction and renovation services." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<script src="https://upload-widget.cloudinary.com/global/all.js" type="text/javascript"></script>
	</head>
	<body class="antialiased min-h-screen flex flex-col font-sans selection:bg-accent selection:text-white bg-[#f9f8f6] text-[#1a1a1a]">
		<slot />
		
		<script>
			if (typeof window !== 'undefined' && typeof document !== 'undefined') {
				// Intersection Observer for scroll animations
				document.addEventListener('DOMContentLoaded', () => {
					const observerOptions = {
						root: null,
						rootMargin: '0px',
						threshold: 0.15
					};

					const observer = new IntersectionObserver((entries, observer) => {
						entries.forEach(entry => {
							if (entry.isIntersecting) {
								entry.target.classList.add('active');
								observer.unobserve(entry.target);
							}
						});
					}, observerOptions);

					const revealElements = document.querySelectorAll('.reveal');
					revealElements.forEach(el => observer.observe(el));

					// Visual CMS Edit Mode Logic
					const isAdmin = localStorage.getItem('isAdmin') === 'true';
					if (isAdmin) {
						document.body.classList.add('admin-mode-active');

						// Inject Logout Button
						const logoutBtn = document.createElement('button');
						logoutBtn.className = 'fixed bottom-6 right-6 z-[100] bg-red-600 hover:bg-red-700 text-white font-sans tracking-widest uppercase text-xs px-6 py-3 rounded-none shadow-2xl transition-colors border border-white/20';
						logoutBtn.innerText = 'Log Out CMS';
						logoutBtn.addEventListener('click', () => {
							localStorage.removeItem('isAdmin');
							window.location.reload();
						});
						document.body.appendChild(logoutBtn);

						// Dynamic Image Overlays
						document.querySelectorAll('img:not(.logo)').forEach((img) => {
							// Exclude header and footer images
							if (img.closest('header') || img.closest('footer')) return;

							const parent = img.parentElement;
							if (parent && !parent.classList.contains('relative')) {
								parent.classList.add('relative');
							}

							const overlay = document.createElement('div');
							overlay.className = 'absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center cursor-pointer z-50';
							overlay.innerHTML = `
								<div class="flex flex-col items-center">
									<svg class="w-8 h-8 text-white mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
									<span class="text-white font-sans tracking-widest uppercase text-xs border border-white/40 px-6 py-2 bg-black/40 shadow-lg">Replace Image</span>
								</div>
							`;
							
							overlay.addEventListener('click', (e) => {
								e.preventDefault();
								e.stopPropagation();
								
								if (typeof window !== 'undefined' && localStorage.getItem('isAdmin') === 'true') {
									// @ts-ignore (Cloudinary global)
									cloudinary.createUploadWidget({
										cloudName: 'dnd3ymq7i',
										uploadPreset: 'ml_default',
										sources: ['local', 'url', 'google_drive'],
										multiple: false,
										theme: 'minimal'
									}, (error, result) => {
										if (!error && result && result.event === "success") {
											console.log("CMS Upload Success:", result.info.secure_url);
											// Update DOM immediately
											(img as HTMLImageElement).src = result.info.secure_url;
											(img as HTMLImageElement).removeAttribute('srcset'); // Clear responsive srcset if present
										}
									}).open();
								}
							});

							if (parent) {
								parent.appendChild(overlay);
							}
						});
					}
				});
			}
		</script>
	</body>
</html>
