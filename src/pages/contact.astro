---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { MapPin, Phone, Mail } from 'lucide-astro';
---

<Layout title="Contact | TORVIX">
  <Header />
  
  <main class="flex-grow pt-32 pb-24 bg-slate-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center reveal mb-16">
        <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-6">Get in Touch</h1>
        <p class="text-xl text-slate-600 max-w-2xl mx-auto">
          Ready to start your next project? Our team is here to answer your questions and bring your vision to life.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 bg-white p-8 md:p-12 rounded-none shadow-sm border border-slate-200 reveal delay-200">
        
        <!-- Left Side: Contact Info -->
        <div class="flex flex-col justify-center">
          <h2 class="text-3xl font-bold text-slate-900 mb-8">Contact Information</h2>
          
          <div class="space-y-8">
            <div class="flex items-start gap-5 group">
              <div class="w-12 h-12 bg-accent-soft rounded-none flex items-center justify-center text-accent flex-shrink-0 group-hover:bg-accent group-hover:text-white transition-colors duration-300">
                <Phone class="w-5 h-5" />
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-1">Phone</p>
                <a href="tel:+14165550123" class="text-xl font-medium text-slate-900 hover:text-accent transition-colors">
                  +1 (416) 555-0123
                </a>
              </div>
            </div>

            <div class="flex items-start gap-5 group">
              <div class="w-12 h-12 bg-accent-soft rounded-none flex items-center justify-center text-accent flex-shrink-0 group-hover:bg-accent group-hover:text-white transition-colors duration-300">
                <Mail class="w-5 h-5" />
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-1">Email</p>
                <a href="mailto:info@sosna.ca" class="text-xl font-medium text-slate-900 hover:text-accent transition-colors">
                  info@sosna.ca
                </a>
              </div>
            </div>

            <div class="flex items-start gap-5 group">
              <div class="w-12 h-12 bg-accent-soft rounded-none flex items-center justify-center text-accent flex-shrink-0 group-hover:bg-accent group-hover:text-white transition-colors duration-300">
                <MapPin class="w-5 h-5" />
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-1">Address</p>
                <p class="text-xl font-medium text-slate-900 leading-relaxed">
                  123 Toronto St,<br />Ontario, Canada
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Side: Google Map -->
        <div class="rounded-none overflow-hidden h-96 w-full shadow-inner bg-slate-100 border border-slate-200">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2887.112959828236!2d-79.38090712384594!3d43.64583155157642!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89d4cb2c48117769%3A0x6b44a2df81c810c2!2sToronto%2C%20ON%2C%20Canada!5e0!3m2!1sen!2sus!4v1714930000000!5m2!1sen!2sus" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            title="Office Location Map"
          ></iframe>
        </div>

      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
