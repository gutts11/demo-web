---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const galleryImages = [
  "/images/düzenlenmiş/Bathroom/After/img_0011.webp",
  "/images/düzenlenmiş/Design/After/img_3853.webp",
  "/images/düzenlenmiş/Addition/Before & During/img_5137.webp",
  "/images/düzenlenmiş/Bathroom/After/img_3845.webp",
  "/images/düzenlenmiş/Design/After/img_4978.webp",
  "/images/düzenlenmiş/Bathroom/After/img_4975.webp",
  "/images/düzenlenmiş/Full Home Renovation/After/img_6012.webp",
  "/images/düzenlenmiş/Bathroom/After/img_5057.webp",
  "/images/düzenlenmiş/Design/After/img_6018.webp",
  "/images/düzenlenmiş/Bathroom/After/img_6017.webp",
  "/images/düzenlenmiş/Kitchen/After/img_6006.webp",
  "/images/düzenlenmiş/Bathroom/After/img_9280.webp",
  "/images/düzenlenmiş/Addition/Before & During/img_9274.webp",
  "/images/düzenlenmiş/Bathroom/After/img_9571.webp",
  "/images/düzenlenmiş/Design/After/img_7140.webp"
];
---

<Layout title="TORVIX - Master Projects Portfolio">
  <Header />
  
  <main class="flex-grow pt-32 lg:pt-40 min-h-screen bg-[#f9f8f6]">
    
    <section class="py-24 lg:py-32">
      <div class="max-w-5xl mx-auto px-6 text-center reveal">
        <h1 class="text-5xl lg:text-7xl font-serif text-[#1a1a1a] mb-8 tracking-tight">
          Master Portfolio
        </h1>
        <p class="text-lg lg:text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed tracking-wide font-sans">
          A curated collection of our most exceptional Toronto architectural transformations. Every image represents our uncompromising dedication to quiet luxury and structural integrity.
        </p>
      </div>
    </section>

    <!-- Master CSS Grid -->
    <section class="pb-32 lg:pb-48 border-t border-slate-200 pt-24 bg-white">
      <div class="max-w-[1600px] mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-10">
          
          {galleryImages.map((src, index) => (
            <div class={`reveal group relative ${index % 5 === 0 ? 'md:col-span-2 lg:col-span-2' : ''}`}>
              <div class="overflow-hidden rounded-none border border-slate-200 bg-slate-100 aspect-square md:aspect-[4/3] w-full">
                <img 
                  src={src} 
                  alt={`Torvix Project ${index + 1}`} 
                  class="w-full h-full object-cover transition-transform duration-[1.5s] ease-in-out group-hover:scale-[1.03]"
                  loading={index < 4 ? "eager" : "lazy"}
                  decoding="async"
                />
              </div>
            </div>
          ))}

        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>
