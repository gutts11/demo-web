---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const images = [
  "/images/projects/Tiling_/CYNTHIA/webp_cikti/img_9888.webp",
  "/images/projects/Tiling_/CYNTHIA/webp_cikti/img_9889.webp"
];
---

<Layout title="TORVIX - Before & After Execution">
	<Header />
	<main class="pt-32 pb-32 lg:pb-40 bg-[#f9f8f6] text-[#1a1a1a]">
        <div class="max-w-7xl mx-auto px-6 mb-16 md:mb-24 mt-8">
            <h1 class="text-4xl lg:text-6xl font-bold tracking-tight mb-6 font-serif reveal">
                Before & After Execution
            </h1>
            <p class="text-lg md:text-xl leading-relaxed max-w-2xl reveal delay-100 font-sans tracking-wide">
                Witness the power of precision engineering and elevated design. We document our transformative process from raw structural potential to finished quiet luxury.
            </p>
        </div>

        <div class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="reveal break-inside-avoid relative overflow-hidden rounded-none border border-slate-200 group">
                    <img 
                        src={images[0]} 
                        alt="Project Execution Phase 1"
                        class="w-full h-[600px] object-cover rounded-none"
                        loading="lazy"
                    />
                    <div class="absolute top-4 left-4 bg-[#1a1a1a] text-white px-4 py-2 font-sans tracking-wide text-sm font-semibold">
                        ROUGH-IN
                    </div>
                </div>
                <div class="reveal break-inside-avoid relative overflow-hidden rounded-none border border-slate-200 group">
                    <img 
                        src={images[1]} 
                        alt="Project Execution Phase 2"
                        class="w-full h-[600px] object-cover rounded-none"
                        loading="lazy"
                    />
                    <div class="absolute top-4 left-4 bg-white text-[#1a1a1a] px-4 py-2 font-sans tracking-wide text-sm font-semibold border border-[#1a1a1a]/10">
                        FINISH
                    </div>
                </div>
            </div>
            <div class="mt-12 text-center max-w-3xl mx-auto reveal delay-200">
                <h2 class="text-3xl font-serif font-semibold mb-6">Foundation to Finish</h2>
                <p class="font-sans tracking-wide leading-relaxed text-[#1a1a1a]/80">
                    Our process is entirely transparent. We believe that the quality hidden behind the drywall—the precision framing, structured wiring, and meticulous plumbing—is exactly what dictates the perfection of the final visual surface. 
                </p>
            </div>
        </div>

	</main>
	<Footer />
</Layout>
