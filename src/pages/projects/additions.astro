---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Additions Gallery - TORVIX">
  <Header />
  <main class="flex-grow flex items-center justify-center py-40 min-h-screen bg-[#f9f8f6]">
    <div class="text-center reveal">
      <span class="inline-block py-1 px-3 rounded-none bg-accent-soft text-accent font-medium text-sm mb-6 border border-accent-border uppercase tracking-widest">
        Project Gallery
      </span>
      <h1 class="text-4xl lg:text-6xl font-serif text-slate-900 mb-6 uppercase tracking-tight">Additions Gallery</h1>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-10 leading-relaxed font-sans">
        Our curated gallery of modern home addition projects is coming soon.
      </p>
      <a href="/" class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white font-medium rounded-none hover:bg-accent-hover transition-all duration-500 ease-in-out uppercase tracking-widest text-xs border border-accent">
        Return Home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
