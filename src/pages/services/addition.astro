---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const images = [
  "/images/projects/Ready pics_/webp_cikti/img_7140.webp",
  "/images/projects/Ready pics_/webp_cikti/img_7451.webp"
];
---

<Layout title="TORVIX - Modern Home Extensions Toronto">
	<Header />
	<main class="pt-32 pb-32 lg:pb-40 bg-[#f9f8f6] text-[#1a1a1a]">
        <div class="max-w-7xl mx-auto px-6 mb-16 md:mb-24 mt-8">
            <h1 class="text-4xl lg:text-6xl font-bold tracking-tight mb-6 font-serif reveal">
                Modern Home Extensions
            </h1>
            <p class="text-lg md:text-xl leading-relaxed max-w-2xl reveal delay-100 font-sans tracking-wide">
                We expand your footprint across Toronto's diverse neighborhoods without compromising architectural continuity. Our additions are structurally engineered and aesthetically designed to look as if they were always part of the original vision.
            </p>
        </div>

        <div class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="reveal break-inside-avoid relative group">
                    <div class="overflow-hidden rounded-none border border-slate-200">
                        <img 
                            src={images[0]} 
                            alt="Home Extension 1"
                            class="w-full h-[600px] object-cover rounded-none"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <p class="mt-4 text-xs font-sans tracking-widest uppercase text-slate-500 border-l border-slate-300 pl-4">
                        Heavy timber and steel structural framing executed to support a significant new footprint.
                    </p>
                </div>
                <div class="reveal delay-200">
                    <h2 class="text-3xl font-serif font-semibold mb-6">Structural Additions & Engineering</h2>
                    <p class="font-sans tracking-wide leading-relaxed mb-6 text-[#1a1a1a]/80">
                        Expanding a home requires complex load-bearing calculations and precision foundation work. We ensure that every extension is robustly integrated into the existing structure, enhancing overall integrity.
                    </p>
                    <ul class="space-y-4 font-sans tracking-wide text-[#1a1a1a]/80">
                        <li class="flex items-start"><span class="mr-3 text-slate-400">01.</span> Advanced Foundation Pouring</li>
                        <li class="flex items-start"><span class="mr-3 text-slate-400">02.</span> Seamless Roof Tie-Ins</li>
                        <li class="flex items-start"><span class="mr-3 text-slate-400">03.</span> High-Performance Framing</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="order-2 lg:order-1 reveal">
                    <h2 class="text-3xl font-serif font-semibold mb-6">Architectural Continuity</h2>
                    <p class="font-sans tracking-wide leading-relaxed text-[#1a1a1a]/80">
                        A true luxury addition never looks 'added on.' We painstakingly match exterior cladding, roofline pitches, and interior finishes to create an uninterrupted flow between the original home and the new space.
                    </p>
                </div>
                <div class="order-1 lg:order-2 reveal delay-200 break-inside-avoid relative group">
                    <div class="overflow-hidden rounded-none border border-slate-200">
                        <img 
                            src={images[1]} 
                            alt="Home Extension 2"
                            class="w-full h-[600px] object-cover rounded-none"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <p class="mt-4 text-xs font-sans tracking-widest uppercase text-slate-500 border-l border-slate-300 pl-4">
                        Precision exterior envelope alignment and weatherproofing before the final facade installation.
                    </p>
                </div>
            </div>
        </div>
	</main>
	<Footer />
</Layout>
