---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const images = [
  "/images/düzenlenmiş/Bathroom/After/img_6017.webp",
  "/images/düzenlenmiş/Bathroom/After/img_6023.webp"
];
---

<Layout title="TORVIX - Premium Basement Conversions Toronto">
	<Header />
	<main class="pt-32 pb-32 lg:pb-40 bg-[#f9f8f6] text-[#1a1a1a]">
        <div class="max-w-7xl mx-auto px-6 mb-16 md:mb-24 mt-8">
            <h1 class="text-4xl lg:text-6xl font-bold tracking-tight mb-6 font-serif reveal">
                Premium Basement Conversions
            </h1>
            <p class="text-lg md:text-xl leading-relaxed max-w-2xl reveal delay-100 font-sans tracking-wide">
                We specialize in turning raw sub-floors into legal secondary suites, premium home theaters, private lounges, and state-of-the-art home gyms. Each project features absolute moisture protection and custom insulation.
            </p>
        </div>

        <div class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="reveal break-inside-avoid relative group">
                    <div class="overflow-hidden rounded-none border border-slate-200 h-64 md:h-[500px] lg:h-[600px] w-full bg-slate-100">
                        <img 
                            src={images[0]} 
                            alt="Basement Framing"
                            class="w-full h-full object-cover rounded-none"
                            decoding="async"
                        />
                    </div>
                    <p class="mt-4 text-xs font-sans tracking-widest uppercase text-slate-500 border-l border-slate-300 pl-4">
                        Sub-floor preparation, damp-proofing, and precision steel/wood framing for a premium basement lounge.
                    </p>
                </div>
                <div class="reveal delay-200">
                    <h2 class="text-3xl font-serif font-semibold mb-6">Structural Preparation & Insulation</h2>
                    <p class="font-sans tracking-wide leading-relaxed mb-6 text-[#1a1a1a]/80">
                        A subterranean space demands flawless climate control. Before applying luxury finishes, we engineer comprehensive sub-floor drainage, advanced spray-foam insulation barriers, and rigorous acoustic dampening specifically for the Toronto climate.
                    </p>
                    <ul class="space-y-4 font-sans tracking-wide text-[#1a1a1a]/80">
                        <li class="flex items-start"><span class="mr-3 text-slate-400">01.</span> Advanced Moisture Protection</li>
                        <li class="flex items-start"><span class="mr-3 text-slate-400">02.</span> Structural Underpinning & Lowering</li>
                        <li class="flex items-start"><span class="mr-3 text-slate-400">03.</span> Closed-Cell Spray Foam Insulation</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="order-2 lg:order-1 reveal">
                    <h2 class="text-3xl font-serif font-semibold mb-6">Legal Suites & Luxury Lounges</h2>
                    <p class="font-sans tracking-wide leading-relaxed text-[#1a1a1a]/80">
                        Whether engineering a fully compliant legal secondary suite or designing a bespoke cinematic home theater, we orchestrate complex plumbing, HVAC, and egress modifications to bring the vision to life seamlessly.
                    </p>
                </div>
                <div class="order-1 lg:order-2 reveal delay-200 break-inside-avoid relative group">
                    <div class="overflow-hidden rounded-none border border-slate-200 h-64 md:h-[500px] lg:h-[600px] w-full bg-slate-100">
                        <img 
                            src={images[1]} 
                            alt="Basement Rough-in"
                            class="w-full h-full object-cover rounded-none"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <p class="mt-4 text-xs font-sans tracking-widest uppercase text-slate-500 border-l border-slate-300 pl-4">
                        Extensive HVAC routing and mechanical upgrades to support a legal subterranean secondary suite.
                    </p>
                </div>
            </div>
        </div>
	</main>
	<Footer />
</Layout>
