---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const images = [
  "/images/projects/Tiling_/CYNTHIA/webp_cikti/img_9571.webp",
  "/images/projects/Tiling_/CYNTHIA/webp_cikti/img_0011.webp"
];
---

<Layout title="TORVIX - Spa Bathrooms Toronto">
	<Header />
	<main class="pt-32 pb-32 lg:pb-40 bg-[#f9f8f6] text-[#1a1a1a]">
        <div class="max-w-7xl mx-auto px-6 mb-16 md:mb-24 mt-8">
            <h1 class="text-4xl lg:text-6xl font-bold tracking-tight mb-6 font-serif reveal">
                Spa Bathroom Builds
            </h1>
            <p class="text-lg md:text-xl leading-relaxed max-w-2xl reveal delay-100 font-sans tracking-wide">
                We engineer intimate, serene environments featuring custom walk-in steam showers, zero-clearance drains, and masterfully aligned premium tiling. Every bathroom is built as a private sanctuary of quiet luxury.
            </p>
        </div>

        <div class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="reveal break-inside-avoid relative group">
                    <div class="overflow-hidden rounded-none border border-slate-200">
                        <img 
                            src={images[0]} 
                            alt="Bathroom Rough-in"
                            class="w-full h-[600px] object-cover rounded-none"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <p class="mt-4 text-xs font-sans tracking-widest uppercase text-slate-500 border-l border-slate-300 pl-4">
                        Advanced plumbing rough-in and pressure testing for a multi-fixture master spa bathroom.
                    </p>
                </div>
                <div class="reveal delay-200">
                    <h2 class="text-3xl font-serif font-semibold mb-6">Advanced Waterproofing & Plumbing</h2>
                    <p class="font-sans tracking-wide leading-relaxed mb-6 text-[#1a1a1a]/80">
                        Behind the pristine tile is a fortress of engineering. We utilize high-end waterproof layering, advanced membrane systems, and precision sub-floor modifications to support zero-threshold showers and radiant heating.
                    </p>
                    <ul class="space-y-4 font-sans tracking-wide text-[#1a1a1a]/80">
                        <li class="flex items-start"><span class="mr-3 text-slate-400">01.</span> Complete Membrane Waterproofing</li>
                        <li class="flex items-start"><span class="mr-3 text-slate-400">02.</span> Walk-In Steam Shower Integration</li>
                        <li class="flex items-start"><span class="mr-3 text-slate-400">03.</span> Zero-Clearance Linear Drains</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="order-2 lg:order-1 reveal">
                    <h2 class="text-3xl font-serif font-semibold mb-6">Meticulous Tile Masonry</h2>
                    <p class="font-sans tracking-wide leading-relaxed text-[#1a1a1a]/80">
                        Our tiling execution is defined by absolute geometric perfection. From massive porcelain slabs to intricate natural stone mosaics, our master masons ensure flawless leveling and microscopic grout line consistency.
                    </p>
                </div>
                <div class="order-1 lg:order-2 reveal delay-200 break-inside-avoid relative group">
                    <div class="overflow-hidden rounded-none border border-slate-200">
                        <img 
                            src={images[1]} 
                            alt="Bathroom Tile Execution"
                            class="w-full h-[600px] object-cover rounded-none"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <p class="mt-4 text-xs font-sans tracking-widest uppercase text-slate-500 border-l border-slate-300 pl-4">
                        Perfect geometric alignment and leveling during a large-format luxury tile installation.
                    </p>
                </div>
            </div>
        </div>
	</main>
	<Footer />
</Layout>
