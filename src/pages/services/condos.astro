---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const images = [
  "/images/düzenlenmiş/Design/After/img_6018.webp",
  "/images/düzenlenmiş/Design/After/img_6024.webp"
];
---

<Layout title="TORVIX - Luxury Condominium Renovations Toronto">
	<Header />
	<main class="pt-32 pb-32 lg:pb-40 bg-[#f9f8f6] text-[#1a1a1a]">
        <div class="max-w-7xl mx-auto px-6 mb-16 md:mb-24 mt-8">
            <h1 class="text-4xl lg:text-6xl font-bold tracking-tight mb-6 font-serif reveal">
                Luxury Condominium Renovations
            </h1>
            <p class="text-lg md:text-xl leading-relaxed max-w-2xl reveal delay-100 font-sans tracking-wide">
                Renovating Toronto downtown towers demands logistical mastery. We execute high-rise spatial planning with strict adherence to condo board regulations, ensuring quiet luxury through advanced soundproofing.
            </p>
        </div>

        <div class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="reveal break-inside-avoid relative group">
                    <div class="overflow-hidden rounded-none border border-slate-200 h-64 md:h-[500px] lg:h-[600px] w-full bg-slate-100">
                        <img 
                            src={images[0]} 
                            alt="Condo Renovation Phase"
                            class="w-full h-full object-cover rounded-none"
                            decoding="async"
                        />
                    </div>
                    <p class="mt-4 text-xs font-sans tracking-widest uppercase text-slate-500 border-l border-slate-300 pl-4">
                        High-rise structural modifications exposing base concrete for luxury floor plan optimization.
                    </p>
                </div>
                <div class="reveal delay-200">
                    <h2 class="text-3xl font-serif font-semibold mb-6">Logistics & Board Compliance</h2>
                    <p class="font-sans tracking-wide leading-relaxed mb-6 text-[#1a1a1a]/80">
                        We optimize premium material delivery and demolition extraction using highly controlled processes. Our team respects the rigid rules of strata living, minimizing disruption while maintaining unprecedented build speed.
                    </p>
                    <ul class="space-y-4 font-sans tracking-wide text-[#1a1a1a]/80">
                        <li class="flex items-start"><span class="mr-3 text-slate-400">01.</span> Elevator Booking & Access Management</li>
                        <li class="flex items-start"><span class="mr-3 text-slate-400">02.</span> Rigorous Condo Board Compliance</li>
                        <li class="flex items-start"><span class="mr-3 text-slate-400">03.</span> Acoustical Isolation Systems</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="order-2 lg:order-1 reveal">
                    <h2 class="text-3xl font-serif font-semibold mb-6">High-Rise Spatial Optimization</h2>
                    <p class="font-sans tracking-wide leading-relaxed text-[#1a1a1a]/80">
                        Urban condominium layouts benefit from strategic wall relocations and reflective surface integration to maximize natural light and panoramic views. We engineer spaces that feel remarkably expansive.
                    </p>
                </div>
                <div class="order-1 lg:order-2 reveal delay-200 break-inside-avoid relative group">
                    <div class="overflow-hidden rounded-none border border-slate-200 h-64 md:h-[500px] lg:h-[600px] w-full bg-slate-100">
                        <img 
                            src={images[1]} 
                            alt="Condo Framing"
                            class="w-full h-full object-cover rounded-none"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <p class="mt-4 text-xs font-sans tracking-widest uppercase text-slate-500 border-l border-slate-300 pl-4">
                        Acoustical dampening channels installed within steel framing for maximum sound isolation.
                    </p>
                </div>
            </div>
        </div>
	</main>
	<Footer />
</Layout>
