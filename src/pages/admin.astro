---
import Layout from '../layouts/Layout.astro';
---

<Layout title="TORVIX - Visual CMS Login">
  <main class="min-h-screen bg-[#f9f8f6] flex flex-col items-center justify-center p-6">
    <div class="w-full max-w-md bg-white p-10 lg:p-14 border border-slate-200 shadow-2xl reveal">
      
      <div class="text-center mb-10">
        <a href="/" class="text-2xl font-serif text-[#1a1a1a] tracking-widest uppercase inline-block mb-4">
            TORVIX <span class="font-sans font-light text-xs align-top">CMS</span>
        </a>
        <p class="text-sm font-sans tracking-wide text-slate-500">
            Enter your credentials to access Visual Edit Mode.
        </p>
      </div>

      <form id="admin-login-form" class="space-y-6">
        <div>
          <label for="password" class="block text-xs font-sans tracking-widest uppercase text-slate-500 mb-2">
            Secure Passphrase
          </label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 focus:outline-none focus:border-[#1a1a1a] focus:ring-0 transition-colors rounded-none font-sans"
            placeholder="••••••••••••"
            required
          />
          <p id="error-msg" class="text-red-500 text-xs mt-2 hidden font-sans tracking-wide">Incorrect credentials.</p>
        </div>

        <button 
          type="submit" 
          class="w-full py-4 bg-[#1a1a1a] text-white font-medium font-sans tracking-widest uppercase text-sm rounded-none hover:bg-slate-800 transition-all duration-300"
        >
          Authenticate
        </button>
      </form>

      <div class="mt-8 text-center">
        <a href="/" class="text-xs font-sans tracking-widest uppercase text-slate-400 hover:text-[#1a1a1a] transition-colors border-b border-transparent hover:border-[#1a1a1a]">
            Return to Live Site
        </a>
      </div>

    </div>
  </main>

  <script>
    if (typeof window !== 'undefined' && typeof document !== 'undefined') {
      document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('admin-login-form');
        const errorMsg = document.getElementById('error-msg');

        if (form) {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            const password = (document.getElementById('password') as HTMLInputElement).value;
            
            if (password === 'TorvixAdmin2026') {
              localStorage.setItem('torvix_admin', 'true');
              window.location.href = '/';
            } else {
              errorMsg?.classList.remove('hidden');
            }
          });
        }
      });
    }
  </script>
</Layout>
