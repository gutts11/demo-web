---
// Services.astro
const services = [
  {
    title: "Custom Home Builds",
    description: "From concept to completion, we build structurally sound and aesthetically stunning custom homes.",
    image: "https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?q=80&w=800"
  },
  {
    title: "Modern Renovations",
    description: "Transform your existing space with premium materials and contemporary design principles.",
    image: "https://images.unsplash.com/photo-1484154218962-a197022b5858?q=80&w=800"
  },
  {
    title: "Commercial Build-Outs",
    description: "Functional, professional spaces designed to elevate your business operations and brand.",
    image: "https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=800"
  },
  {
    title: "Exterior Makeovers",
    description: "Boost curb appeal with our exterior renovation services, including siding, roofing, and facades.",
    image: "https://images.unsplash.com/photo-1512917774080-9991f1c4c750?q=80&w=800"
  }
];
---
<section id="services" class="py-32 lg:py-40 bg-white relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-16 md:mb-24 max-w-2xl reveal">
      <h2 class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 mb-6 font-serif">
        Our Expertise
      </h2>
      <p class="text-lg text-slate-600 leading-relaxed mb-8">
        We deliver uncompromising quality across a range of specialized construction services. Every project is executed with precision and care.
      </p>
      <a href="/services" class="inline-flex items-center justify-center px-8 py-3 bg-accent text-white font-medium text-base rounded-none hover:bg-accent-hover hover:shadow-lg transition-all duration-500 ease-in-out border border-slate-900">
        Learn more
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      {services.map((service, index) => {
        // Calculate a staggered delay class based on the index
        // Even indices get delay-100, odd get delay-200 to stagger nicely on grid
        const delayClass = index % 2 === 0 ? 'delay-100' : 'delay-200';
        return (
          <div class={`reveal ${delayClass} group`}>
            <div class="relative overflow-hidden rounded-none mb-6 bg-slate-100 aspect-[4/3] border border-slate-200">
              <img 
                src={service.image} 
                alt={service.title} 
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-slate-900/10 group-hover:bg-transparent transition-colors duration-500"></div>
            </div>
            <h3 class="text-2xl font-semibold text-slate-900 mb-3 group-hover:text-accent transition-colors font-serif">
              {service.title}
            </h3>
            <p class="text-slate-600 leading-relaxed">
              {service.description}
            </p>
          </div>
        );
      })}
    </div>
  </div>
</section>
