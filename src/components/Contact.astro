---
// Contact.astro
---
<section id="contact" class="py-32 lg:py-40 bg-white relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-4xl mx-auto">
      
      <div class="text-center mb-16 reveal">
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight text-slate-900 mb-4 font-serif">
          Ready to Start Your Project?
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Contact us today to discuss your vision. Our team is ready to bring your ideas to life with precision and excellence.
        </p>
      </div>

      <div class="bg-slate-50 rounded-none p-8 lg:p-12 shadow-sm border border-slate-200 reveal delay-100">
        <form class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="firstName" class="text-sm font-medium text-slate-700">First Name</label>
            <input type="text" id="firstName" name="firstName" class="w-full px-4 py-3 rounded-none border border-slate-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-shadow bg-white" placeholder="John" required />
          </div>
          <div class="space-y-2">
            <label for="lastName" class="text-sm font-medium text-slate-700">Last Name</label>
            <input type="text" id="lastName" name="lastName" class="w-full px-4 py-3 rounded-none border border-slate-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-shadow bg-white" placeholder="Doe" required />
          </div>
          <div class="space-y-2 md:col-span-2">
            <label for="email" class="text-sm font-medium text-slate-700">Email Address</label>
            <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-none border border-slate-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-shadow bg-white" placeholder="john@example.com" required />
          </div>
          <div class="space-y-2 md:col-span-2">
            <label for="service" class="text-sm font-medium text-slate-700">Service Needed</label>
            <select id="service" name="service" class="w-full px-4 py-3 rounded-none border border-slate-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-shadow bg-white text-slate-700">
              <option value="" disabled selected>Select a service</option>
              <option value="custom-home">Custom Home Build</option>
              <option value="renovation">Renovation</option>
              <option value="commercial">Commercial Build-Out</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="space-y-2 md:col-span-2">
            <label for="message" class="text-sm font-medium text-slate-700">Project Details</label>
            <textarea id="message" name="message" rows="5" class="w-full px-4 py-3 rounded-none border border-slate-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-shadow bg-white resize-none" placeholder="Tell us about your vision..." required></textarea>
          </div>
          <div class="md:col-span-2 pt-4">
            <button type="submit" class="w-full py-4 bg-cta-bg text-white font-medium rounded-none border border-slate-900 hover:bg-accent-hover hover:shadow-lg transition-all duration-500 ease-in-out text-lg">
              Request a Consultation
            </button>
          </div>
        </form>
      </div>

    </div>
  </div>
</section>
